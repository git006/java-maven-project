name: Build and Push Docker Image

on:
  push:
    branches: [ "main", "master" ]

# 关键：赋予工作流向你的 GitHub Packages 写入镜像的权限
permissions:
  contents: read
  packages: write

jobs:
  build-and-push:
    runs-on: ubuntu-latest

    steps:
    # 1. 拉取源码
    - name: Checkout Code
      uses: actions/checkout@v4

    # 2. 设置 JDK 并利用缓存编译出 jar 包
    - name: Set up JDK 17
      uses: actions/setup-java@v4
      with:
        java-version: '17'
        distribution: 'temurin'
        cache: 'maven'

    # 3. 执行 Maven 打包（跳过测试以加快速度，或者保留 mvn clean verify）
    - name: Build with Maven
      run: mvn -B clean package -DskipTests

    # 4. 登录到 GitHub 官方镜像仓库 (GHCR)
    # github.token 是内置变量，个人账号无需手动配置密钥，开箱即用
    - name: Log in to GitHub Container Registry
      uses: docker/login-action@v3
      with:
        registry: ghcr.io
        username: ${{ github.actor }}
        password: ${{ secrets.GITHUB_TOKEN }}

    # 5. 设置 Docker Buildx（用于加速和高级构建特性）
    - name: Set up Docker Buildx
      uses: docker/setup-buildx-action@v3

    # 6. 构建并推送 Docker 镜像
    - name: Build and Push Docker Image
      uses: docker/build-push-action@v6
      with:
        context: .
        file: ./Dockerfile
        push: true
        # 镜像标签名格式：ghcr.io/你的用户名/项目名:latest
        tags: |
          ghcr.io/${{ github.actor }}/java-maven-project:latest