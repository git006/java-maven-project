name: Java Maven Build Jar

on:
  push:
    branches: [ "main", "master" ]
  pull_request:
    branches: [ "main", "master" ]

jobs:
  build-jar:
    runs-on: ubuntu-latest

    steps:
    # 1. 拉取源码
    - name: Checkout Code
      uses: actions/checkout@v4

    # 2. 设置 JDK 17 并配置缓存
    - name: Set up JDK 17
      uses: actions/setup-java@v4
      with:
        java-version: '17'
        distribution: 'temurin'
        cache: 'maven'

    # 3. 执行 Maven 打包（包含跑单测，确保代码无误再打包）
    - name: Build Jar with Maven
      run: mvn -B clean package

    # 4. 关键步骤：把 target 目录下的 jar 包保存到 GitHub 云端
    - name: Upload Build Artifact
      uses: actions/upload-artifact@v4
      with:
        name: java-app-jar  # 给你下载的压缩包起个名字
        path: target/*.jar  # 指定要保存的文件路径（匹配 target 下所有的 jar 包）
        retention-days: 5   # 在 GitHub 上保留 5 天，过期自动删除，省空间